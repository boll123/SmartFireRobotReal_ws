<?xml version="1.0" encoding="utf-8"?>
<robot name="Fullbody_re1" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="sim_mode" default="false" />

  <!-- ═══ base_footprint ═══ -->
  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_footprint" />
    <child link="base_link" />
  </joint>
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="0.0036955 0.0031256 0.1294"
        rpy="0 0 0" />
      <mass
        value="21" />
      <inertia
        ixx="0.093954"
        ixy="-4.3239E-06"
        ixz="1.2903E-06"
        iyy="0.058762"
        iyz="1.9861E-06"
        izz="0.14411" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>
  <link
    name="HoverWheelL_Link">
    <inertial>
      <origin
        xyz="2.2204E-16 -0.023057 -1.1E-05"
        rpy="0 0 0" />
      <mass
        value="2.07" />
      <inertia
        ixx="0.0018049"
        ixy="1.7829E-19"
        ixz="-5.0371E-23"
        iyy="0.0031325"
        iyz="-6.423E-07"
        izz="0.0018049" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/HoverWheelL_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/HoverWheelL_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="HoverWheelL_joint"
    type="continuous">
    <origin
      xyz="-0.127 0.286 0.013"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="HoverWheelL_Link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="CasterWheelL_Link">
    <inertial>
      <origin
        xyz="-2.2204E-16 -0.022 -1.1102E-16"
        rpy="0 0 0" />
      <mass
        value="0.209" />
      <inertia
        ixx="9.5074E-06"
        ixy="-1.5661E-23"
        ixz="7.9045E-22"
        iyy="1.4188E-05"
        iyz="-2.886E-23"
        izz="9.5074E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/CasterWheelL_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.29412 0.29412 0.29412 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/CasterWheelL_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="CasterWheelL_joint"
    type="continuous">
    <origin
      xyz="0.1666 0.2135 -0.0442"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="CasterWheelL_Link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="HoverWheelR_Link">
    <inertial>
      <origin
        xyz="-2.2204E-15 0.023057 -1.1E-05"
        rpy="0 0 0" />
      <mass
        value="2.07" />
      <inertia
        ixx="0.0018049"
        ixy="1.7473E-18"
        ixz="-3.8369E-22"
        iyy="0.0031325"
        iyz="6.423E-07"
        izz="0.0018049" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/HoverWheelR_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/HoverWheelR_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="HoverWheelR_joint"
    type="continuous">
    <origin
      xyz="-0.127 -0.286 0.013"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="HoverWheelR_Link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="CasterWheelR_Link">
    <inertial>
      <origin
        xyz="4.4409E-16 0.022 0"
        rpy="0 0 0" />
      <mass
        value="0.209" />
      <inertia
        ixx="9.5074E-06"
        ixy="-1.9611E-23"
        ixz="-1.5351E-23"
        iyy="1.4188E-05"
        iyz="-2.6175E-22"
        izz="9.5074E-06" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/CasterWheelR_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.29412 0.29412 0.29412 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/CasterWheelR_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="CasterWheelR_joint"
    type="continuous">
    <origin
      xyz="0.1666 -0.2135 -0.0442"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="CasterWheelR_Link" />
    <axis
      xyz="0 1 0" />
  </joint>
  <link
    name="laser_frame">
    <inertial>
      <origin
        xyz="-0.011678 0.00041342 -0.035501"
        rpy="0 0 0" />
      <mass
        value="0.17" />
      <inertia
        ixx="2.7909E-05"
        ixy="-5.2517E-08"
        ixz="3.3534E-07"
        iyy="4.4353E-05"
        iyz="-2.4873E-08"
        izz="6.9475E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/Laser_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/Laser_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="laser_joint"
    type="fixed">
    <origin
      xyz="0.20674 -0.00062164 0.18463"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="laser_frame" />
    <axis
      xyz="0 0 0" />
  </joint>
  <link
    name="imu_link">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.06" />
      <inertia
        ixx="0"
        ixy="0"
        ixz="0"
        iyy="0"
        iyz="0"
        izz="0" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/IMU_Link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file:///home/admin01/SmartFireRobotReal_ws/src/joy_control/meshes/IMU_Link.STL" />
      </geometry>
    </collision>
  </link>
  <joint
    name="imu_joint"
    type="fixed">
    <origin
      xyz="-0.117 0 0.005"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="imu_link" />
    <axis
      xyz="0 0 0" />
  </joint>

  <!-- ═══════════════════════════════════════════════════════════
       Gazebo Materials & Physics
  ════════════════════════════════════════════════════════════════ -->
  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="HoverWheelL_Link">
    <material>Gazebo/Grey</material>
    <mu1>100.0</mu1>
    <mu2>50.0</mu2>
  </gazebo>
  <gazebo reference="HoverWheelR_Link">
    <material>Gazebo/Grey</material>
    <mu1>100.0</mu1>
    <mu2>50.0</mu2>
  </gazebo>
  <gazebo reference="CasterWheelL_Link">
    <material>Gazebo/Grey</material>
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>
  <gazebo reference="CasterWheelR_Link">
    <material>Gazebo/Grey</material>
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>0.1</maxVel>
  </gazebo>

  <!-- ═══ Laser Sensor (Gazebo) ═══ -->
  <gazebo reference="laser_frame">
    <material>Gazebo/Red</material>
    <sensor type="ray" name="laser_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>25</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.6</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ═══ IMU Sensor (sim only) ═══ -->
  <xacro:if value="$(arg sim_mode)">
    <gazebo reference="imu_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>50</update_rate>
        <visualize>true</visualize>
        <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
          <ros>
            <remapping>~/out:=/imu/data_raw</remapping>
          </ros>
          <initial_orientation_as_reference>false</initial_orientation_as_reference>
          <frame_name>imu_link</frame_name>
        </plugin>
        <pose>0 0 0 0 0 0</pose>
      </sensor>
    </gazebo>
  </xacro:if>

  <!-- ═══ gazebo_ros2_control (sim only) ═══ -->
  <xacro:if value="$(arg sim_mode)">
    <gazebo>
      <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
        <parameters>$(find joy_control)/config/ros2_controllersSim.yaml</parameters>
      </plugin>
    </gazebo>
  </xacro:if>

  <!-- ═══════════════════════════════════════════════════════════
       ros2_control — Real Robot
  ════════════════════════════════════════════════════════════════ -->
  <xacro:unless value="$(arg sim_mode)">
    <ros2_control name="RealRobot" type="system">
      <hardware>
        <plugin>esp32_hardware/Esp32HardwareInterface</plugin>
        <param name="wheel_radius">0.0826</param>
        <param name="wheel_separation">0.572</param><!-- 0.314*2 จาก joint origin y -->
        <param name="rpm_deadzone">3.0</param>
        <param name="rpm_lpf_alpha">0.20</param>
        <param name="cmd_publish_rate">20.0</param>
        <param name="max_omega">7.33</param>
        <param name="dead_band">0.05</param>
        <param name="cmd_timeout_ms">200.0</param>
        <param name="trim_ratio">1.0</param>
      </hardware>
      <joint name="HoverWheelL_joint">
        <command_interface name="velocity" />
        <state_interface name="position" />
        <state_interface name="velocity" />
      </joint>
      <joint name="HoverWheelR_joint">
        <command_interface name="velocity" />
        <state_interface name="position" />
        <state_interface name="velocity" />
      </joint>
      <joint name="CasterWheelL_joint">
        <state_interface name="position" />
        <state_interface name="velocity" />
      </joint>
      <joint name="CasterWheelR_joint">
        <state_interface name="position" />
        <state_interface name="velocity" />
      </joint>
    </ros2_control>
  </xacro:unless>

  <!-- ═══════════════════════════════════════════════════════════
       ros2_control — Sim
  ════════════════════════════════════════════════════════════════ -->
  <xacro:if value="$(arg sim_mode)">
    <ros2_control name="SimSystem" type="system">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>
      <joint name="HoverWheelL_joint">
        <command_interface name="velocity">
          <param name="min">-10</param>
          <param name="max">10</param>
        </command_interface>
        <state_interface name="velocity">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
      </joint>
      <joint name="HoverWheelR_joint">
        <command_interface name="velocity">
          <param name="min">-10</param>
          <param name="max">10</param>
        </command_interface>
        <state_interface name="velocity">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
      </joint>
      <joint name="CasterWheelL_joint">
        <state_interface name="position" />
        <state_interface name="velocity" />
      </joint>
      <joint name="CasterWheelR_joint">
        <state_interface name="position" />
        <state_interface name="velocity" />
      </joint>
    </ros2_control>
  </xacro:if>

</robot>
